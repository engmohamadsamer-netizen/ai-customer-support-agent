    {
      "parameters": {
        "authentication": "serviceAccount",
        "sendTo": "={{ $('Normalize Data').item.json.email }}",
        "subject": "Your Support Request - OXIVAR AI",
        "message": "=<!DOCTYPE html>\n<html>\n\n<head>\n<meta charset=\"UTF-8\">\n</head>\n\n<body style=\"margin:0;padding:0;background:#f4f7fb;font-family:Arial,Helvetica,sans-serif;\">\n\n<table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"background:#f4f7fb;padding:40px 0;\">\n\n<tr>\n<td align=\"center\">\n\n<table width=\"600\" cellpadding=\"0\" cellspacing=\"0\" style=\"background:#ffffff;border-radius:12px;overflow:hidden;box-shadow:0 10px 25px rgba(0,0,0,.08);\">\n\n<tr>\n\n<td style=\"background:#1f5fbf;padding:30px;text-align:center;\">\n\n<img\nsrc=\"https://raw.githubusercontent.com/engmohamadsamer-netizen/ai-customer-support-agent/main/assets/logo-horizontal.png\"\nalt=\"OXIVAR AI\"\nstyle=\"height:55px;display:block;margin:auto;\">\n\n</td>\n\n</tr>\n\n<tr>\n\n<td style=\"padding:40px;\">\n\n<h2 style=\"margin-top:0;color:#111827;\">\n\nHello {{ $('Normalize Data').item.json.name }},\n\n</h2>\n\n<p style=\"font-size:16px;color:#4b5563;line-height:1.7;\">\n\nThank you for contacting <strong>OXIVAR AI</strong>.\n\n</p>\n\n<p style=\"font-size:16px;color:#4b5563;line-height:1.7;\">\n\nOur AI Customer Support Assistant has successfully received your request and generated the following response.\n\n</p>\n\n<div style=\"margin:35px 0;padding:20px;background:#f8fafc;border-left:5px solid #1f5fbf;border-radius:8px;\">\n\n<p style=\"margin:0;font-size:14px;color:#6b7280;font-weight:bold;\">\n\nCUSTOMER QUESTION\n\n</p>\n\n<p style=\"margin-top:12px;font-size:16px;color:#111827;line-height:1.7;\">\n\n{{ $('Normalize Data').item.json.question }}\n\n</p>\n\n</div>\n\n<div style=\"margin:35px 0;padding:20px;background:#eef5ff;border-left:5px solid #2563eb;border-radius:8px;\">\n\n<p style=\"margin:0;font-size:14px;color:#2563eb;font-weight:bold;\">\n\nAI ASSISTANT RESPONSE\n\n</p>\n\n<p style=\"margin-top:12px;font-size:16px;color:#111827;line-height:1.8;white-space:pre-line;\">\n\n{{ $json.output }}\n\n</p>\n\n</div>\n\n<p style=\"font-size:15px;color:#4b5563;line-height:1.7;\">\n\nIf you need any additional assistance or have further questions, simply reply to this email.\n\nOur team will be happy to assist you.\n\n</p>\n\n<hr style=\"border:none;border-top:1px solid #e5e7eb;margin:35px 0;\">\n\n<table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\">\n\n<tr>\n\n<td width=\"70\">\n\n<img\nsrc=\"https://raw.githubusercontent.com/engmohamadsamer-netizen/ai-customer-support-agent/main/assets/logo-horizontal.png\"\nalt=\"OXIVAR AI\"\nstyle=\"height:45px;display:block;\">\n\n</td>\n\n<td style=\"padding-left:15px;font-size:14px;color:#374151;line-height:1.7;\">\n\n<strong style=\"font-size:16px;\">\n\nOXIVAR AI\n\n</strong>\n\n<br>\n\n<span style=\"color:#6b7280;\">\n\nIntelligent Automation Solutions\n\n</span>\n\n<br><br>\n\n<span style=\"color:#6b7280;\">\n\nAI Automation \u2022 AI Agents \u2022 Workflow Automation\n\n</span>\n\n<br>\n\n<span style=\"color:#6b7280;\">\n\nBusiness Intelligence Solutions\n\n</span>\n\n</td>\n\n</tr>\n\n</table>\n\n<hr style=\"border:none;border-top:1px solid #e5e7eb;margin:35px 0;\">\n\n<p style=\"font-size:12px;color:#9ca3af;text-align:center;line-height:1.6;\">\n\nThis email was generated automatically by the OXIVAR AI Customer Support Agent.\n\n<br>\n\n\u00a9 2026 OXIVAR AI. All rights reserved.\n\n</p>\n\n</td>\n\n</tr>\n\n</table>\n\n</td>\n\n</tr>\n\n</table>\n\n</body>\n\n</html>",
        "options": {
          "appendAttribution": false
        }
      },
